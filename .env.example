# ==============================================================================
# HealthIntel - Environment Configuration
# ==============================================================================

# --- API & Frontend Settings ---
# URL where the FastAPI backend is running (used by Streamlit)
HEALTHINTEL_BACKEND_URL=http://localhost:8000

# Port configurations
BACKEND_PORT=8000
FRONTEND_PORT=8501

# --- Security & Authentication (For upcoming Login feature) ---
# Secret key for signing JWT tokens. 
# Generate a secure key using: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- External APIs ---
# Note: Currently, HealthIntel uses OpenStreetMap's Overpass API for hospital
# recommendations which is 100% FREE and requires NO API KEY. 
# However, if you wish to upgrade to Google Maps in the future, add the key below:

# GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
