# ==============================================================================
# HealthIntel - Environment Configuration
# ==============================================================================

# --- API & Frontend Settings ---
# URL where the FastAPI backend is running (used by Streamlit)
HEALTHINTEL_BACKEND_URL=http://localhost:8000

# Port configurations
BACKEND_PORT=8000
FRONTEND_PORT=8501

# --- Security & Authentication (For upcoming Login feature) ---
# Secret key for signing JWT tokens. 
# Generate a secure key using: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- External APIs ---
# Note: By default, HealthIntel uses OpenStreetMap's Overpass API for hospital
# recommendations which is 100% FREE and requires NO API KEY.
# However, if you want a faster and more reliable free alternative, you can use Geoapify.
# Geoapify gives you 3,000 free requests per day.
#
# INSTRUCTIONS TO GET GEOAPIFY API KEY:
# 1. Go to https://myprojects.geoapify.com/
# 2. Create a free account.
# 3. Create a new project.
# 4. Copy the API Key and paste it below.

GEOAPIFY_API_KEY=2d0f3c0795d04e3fbffb4098d7c66dcb
